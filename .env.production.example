# Production Environment Variables
# Copy this file to .env.production and update with your values

# Application
NODE_ENV=production
PORT=3001

# Database
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=your-secure-mongodb-password
MONGODB_URI=mongodb://admin:your-secure-mongodb-password@localhost:27017/factory_management?authSource=admin

# Security
JWT_SECRET=your-super-secure-jwt-secret-key-change-this-in-production

# URLs
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://yourdomain.com/api

# GitHub Container Registry
GITHUB_REPOSITORY=your-username/factory-management-platform

# SSL (if using custom certificates)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Monitoring (optional)
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
